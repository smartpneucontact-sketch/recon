# Required in production. Generate a long random string (e.g. `openssl rand -hex 32`).
SESSION_SECRET=replace-with-a-long-random-string

# Where SQLite DB and uploaded photos live.
# On Railway, mount your volume at /data and set DATA_DIR=/data
DATA_DIR=./data

# Port (Railway sets this automatically)
PORT=3000

NODE_ENV=production

# --- Twilio SMS (optional) ---
# If any of these three are missing, SMS notifications are disabled gracefully (server boots fine).
# Get them from Twilio Console -> Account.  TWILIO_FROM is the E.164 phone number you bought
# (toll-free is easiest in the US — skip A2P 10DLC registration).
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_FROM=+18005551234

# Optional: WhatsApp via Twilio. Skip A2P 10DLC entirely.
# - For testing: use Twilio's Sandbox number 'whatsapp:+14155238886'. Each recipient
#   must first text the sandbox join code (shown in Console -> Messaging -> Try it out
#   -> Send a WhatsApp Message) from WhatsApp before they can receive messages.
# - For production: get a Twilio-approved WhatsApp sender (requires Meta Business
#   Verification, takes days). Replace below with 'whatsapp:+1...your number...'.
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
