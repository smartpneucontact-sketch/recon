# Required in production. Generate a long random string (e.g. `openssl rand -hex 32`).
SESSION_SECRET=replace-with-a-long-random-string

# Where SQLite DB and uploaded photos live.
# On Railway, mount your volume at /data and set DATA_DIR=/data
DATA_DIR=./data

# Port (Railway sets this automatically)
PORT=3000

NODE_ENV=production

# --- Twilio SMS (optional) ---
# If any of these three are missing, SMS notifications are disabled gracefully (server boots fine).
# Get them from Twilio Console -> Account.  TWILIO_FROM is the E.164 phone number you bought
# (toll-free is easiest in the US — skip A2P 10DLC registration).
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_FROM=+18005551234

# --- Meta WhatsApp Cloud API (optional) ---
# Direct integration with Meta's WhatsApp Business Platform, no middleman.
# Free tier: ~1,000 service conversations / month. Get the two values from
# developers.facebook.com -> your app -> WhatsApp -> Getting Started:
#   META_WHATSAPP_PHONE_NUMBER_ID  -- the "Phone number ID" Meta gives the test number
#   META_WHATSAPP_ACCESS_TOKEN     -- the short-lived 24h token, or a permanent
#                                     System User token for production
# Sending requires the recipient's number to be a verified WhatsApp number (or one
# of the 5 test numbers Meta lets you add for free in the same UI). If either env
# var is missing the server boots fine and WhatsApp sends are gracefully disabled.
# META_WHATSAPP_PHONE_NUMBER_ID=123456789012345
# META_WHATSAPP_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxx
# META_WHATSAPP_VERSION=v20.0   (optional; default v20.0)
